{
  "expo": {
    "name": "mesh-alert",
    "slug": "mesh-alert",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/alert.png",
    "scheme": "mesh-alert",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/alert.png",
        "backgroundImage": "./assets/alert.png",
        "monochromeImage": "./assets/alert.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jordanlaylor0.meshalert"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/alert.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/alert.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "react-native-ble-plx"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "70950694-ae96-4624-8df8-179fd6c75996"
      }
    }
  }
}
